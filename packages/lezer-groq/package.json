{
  "name": "@sanity/lezer-groq",
  "version": "0.0.0",
  "description": "Lezer grammar for GROQ query language (CodeMirror 6)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src/groq.grammar"
  ],
  "scripts": {
    "build": "lezer-generator src/groq.grammar -o src/parser && rollup -c",
    "build:debug": "lezer-generator src/groq.grammar --names -o src/parser && rollup -c"
  },
  "dependencies": {
    "@codemirror/language": "^6.0.0",
    "@lezer/common": "^1.2.0",
    "@lezer/highlight": "^1.0.0",
    "@lezer/lr": "^1.0.0"
  },
  "devDependencies": {
    "@lezer/generator": "^1.7.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "rollup": "^4.0.0"
  }
}
