{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GROQ",
  "scopeName": "source.groq",
  "patterns": [{"include": "#expression"}],
  "repository": {
    "expression": {
      "patterns": [
        {"include": "#comment"},
        {"include": "#string-double"},
        {"include": "#string-single"},
        {"include": "#number"},
        {"include": "#keyword"},
        {"include": "#namespace-call"},
        {"include": "#function-call"},
        {"include": "#operator-keyword"},
        {"include": "#variable"},
        {"include": "#variable-special"},
        {"include": "#wildcard"},
        {"include": "#operator"},
        {"include": "#pipe"},
        {"include": "#accessor"},
        {"include": "#filter"},
        {"include": "#projection"},
        {"include": "#group"},
        {"include": "#punctuation"},
        {"include": "#identifier"}
      ]
    },
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.groq"
    },
    "string-double": {
      "begin": "\"",
      "beginCaptures": {
        "0": {"name": "punctuation.definition.string.begin.groq"}
      },
      "end": "\"",
      "endCaptures": {
        "0": {"name": "punctuation.definition.string.end.groq"}
      },
      "name": "string.quoted.double.groq",
      "patterns": [{"include": "#string-escape"}]
    },
    "string-single": {
      "begin": "'",
      "beginCaptures": {
        "0": {"name": "punctuation.definition.string.begin.groq"}
      },
      "end": "'",
      "endCaptures": {
        "0": {"name": "punctuation.definition.string.end.groq"}
      },
      "name": "string.quoted.single.groq",
      "patterns": [{"include": "#string-escape"}]
    },
    "string-escape": {
      "match": "\\\\(?:[\"\\\\'/bfnrt]|u[0-9a-fA-F]{4}|u\\{[0-9a-fA-F]+\\})",
      "name": "constant.character.escape.groq"
    },
    "number": {
      "match": "(?<![\\w])-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?(?![\\w])",
      "name": "constant.numeric.groq"
    },
    "keyword": {
      "match": "\\b(?:true|false|null)\\b",
      "name": "keyword.constant.groq"
    },
    "variable": {
      "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*",
      "name": "variable.parameter.groq"
    },
    "variable-special": {
      "match": "@|\\^+",
      "name": "variable.language.groq"
    },
    "wildcard": {
      "match": "\\*(?=\\s*[\\[{|)\\],}]|\\s*$)",
      "name": "variable.language.wildcard.groq"
    },
    "operator-keyword": {
      "patterns": [
        {
          "match": "\\bin\\b",
          "name": "keyword.operator.logical.in.groq"
        },
        {
          "match": "\\bmatch\\b",
          "name": "keyword.operator.match.groq"
        },
        {
          "match": "\\b(?:asc|desc)\\b",
          "name": "keyword.operator.sort.groq"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "match": "==|!=",
          "name": "keyword.operator.comparison.groq"
        },
        {
          "match": "<=|>=",
          "name": "keyword.operator.comparison.groq"
        },
        {
          "match": "=>",
          "name": "keyword.operator.pair.groq"
        },
        {
          "match": "->",
          "name": "keyword.operator.dereference.groq"
        },
        {
          "match": "<|>",
          "name": "keyword.operator.comparison.groq"
        },
        {
          "match": "&&",
          "name": "keyword.operator.logical.and.groq"
        },
        {
          "match": "\\|\\|",
          "name": "keyword.operator.logical.or.groq"
        },
        {
          "match": "!",
          "name": "keyword.operator.logical.not.groq"
        },
        {
          "match": "\\*\\*",
          "name": "keyword.operator.arithmetic.exponentiation.groq"
        },
        {
          "match": "[+\\-/%]",
          "name": "keyword.operator.arithmetic.groq"
        },
        {
          "match": "\\*(?!\\*)",
          "name": "keyword.operator.arithmetic.groq"
        },
        {
          "match": "\\.\\.\\.",
          "name": "keyword.operator.ellipsis.groq"
        },
        {
          "match": "\\.\\.(?!\\.)",
          "name": "keyword.operator.range.groq"
        }
      ]
    },
    "pipe": {
      "match": "\\|(?!\\|)",
      "name": "keyword.operator.pipe.groq"
    },
    "accessor": {
      "match": "\\.(?!\\.)",
      "name": "punctuation.accessor.dot.groq"
    },
    "filter": {
      "begin": "\\[",
      "beginCaptures": {
        "0": {"name": "punctuation.definition.bracket.square.begin.groq"}
      },
      "end": "\\]",
      "endCaptures": {
        "0": {"name": "punctuation.definition.bracket.square.end.groq"}
      },
      "patterns": [{"include": "#expression"}]
    },
    "projection": {
      "begin": "\\{",
      "beginCaptures": {
        "0": {"name": "punctuation.definition.bracket.curly.begin.groq"}
      },
      "end": "\\}",
      "endCaptures": {
        "0": {"name": "punctuation.definition.bracket.curly.end.groq"}
      },
      "patterns": [{"include": "#expression"}]
    },
    "group": {
      "begin": "\\(",
      "beginCaptures": {
        "0": {"name": "punctuation.definition.bracket.round.begin.groq"}
      },
      "end": "\\)",
      "endCaptures": {
        "0": {"name": "punctuation.definition.bracket.round.end.groq"}
      },
      "patterns": [{"include": "#expression"}]
    },
    "punctuation": {
      "patterns": [
        {
          "match": ",",
          "name": "punctuation.separator.comma.groq"
        },
        {
          "match": ":(?!:)",
          "name": "punctuation.separator.colon.groq"
        },
        {
          "match": ";",
          "name": "punctuation.separator.semicolon.groq"
        }
      ]
    },
    "namespace-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(::)([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": {"name": "entity.name.namespace.groq"},
        "2": {"name": "punctuation.separator.namespace.groq"},
        "3": {"name": "support.function.groq"}
      }
    },
    "function-call": {
      "match": "\\b(coalesce|count|dateTime|defined|length|now|references|round|select|string|lower|upper|boost|after|before|identity|path|order|score)(?=\\s*\\()",
      "name": "support.function.groq"
    },
    "identifier": {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
      "name": "variable.other.property.groq"
    }
  }
}
