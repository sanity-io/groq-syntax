{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GROQ",
  "scopeName": "source.groq",
  "patterns": [
    { "include": "#expression" }
  ],
  "repository": {
    "expression": {
      "patterns": [
        { "include": "#comment" }
      ]
    },
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.groq"
    }
  }
}
