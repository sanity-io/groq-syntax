{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GROQ Injection (JavaScript/TypeScript)",
  "scopeName": "groq-injection.js",
  "injectionSelector": "L:source.js, L:source.ts, L:source.tsx, L:source.jsx",
  "patterns": [
    { "include": "#groq-tagged-template" },
    { "include": "#groq-comment-tagged-template" },
    { "include": "#groq-define-query" },
    { "include": "#groq-comment-inside-template" }
  ],
  "repository": {
    "groq-tagged-template": {
      "comment": "groq`...` tagged template literal",
      "begin": "(?i)(groq)\\s*(`)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.tagged-template.js" },
        "2": { "name": "punctuation.definition.string.template.begin.js" }
      },
      "end": "(`)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.template.end.js" }
      },
      "contentName": "meta.embedded.block.groq source.groq",
      "patterns": [
        { "include": "#template-substitution" },
        { "include": "source.groq" }
      ]
    },
    "groq-comment-tagged-template": {
      "comment": "/* groq */ `...` comment-tagged template literal",
      "begin": "(/\\*\\s*groq\\s*\\*/)\\s*(`)",
      "beginCaptures": {
        "1": { "name": "comment.block.js" },
        "2": { "name": "punctuation.definition.string.template.begin.js" }
      },
      "end": "(`)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.template.end.js" }
      },
      "contentName": "meta.embedded.block.groq source.groq",
      "patterns": [
        { "include": "#template-substitution" },
        { "include": "source.groq" }
      ]
    },
    "groq-define-query": {
      "comment": "defineQuery(`...`) function call",
      "begin": "(defineQuery)\\s*\\(\\s*(`)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.js" },
        "2": { "name": "punctuation.definition.string.template.begin.js" }
      },
      "end": "(`)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.template.end.js" }
      },
      "contentName": "meta.embedded.block.groq source.groq",
      "patterns": [
        { "include": "#template-substitution" },
        { "include": "source.groq" }
      ]
    },
    "groq-comment-inside-template": {
      "comment": "`// groq\\n...` comment prefix inside template literal",
      "begin": "(`)\\s*//\\s*groq\\s*\\n",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.template.begin.js" }
      },
      "end": "(`)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.template.end.js" }
      },
      "contentName": "meta.embedded.block.groq source.groq",
      "patterns": [
        { "include": "#template-substitution" },
        { "include": "source.groq" }
      ]
    },
    "template-substitution": {
      "comment": "Template literal ${...} substitutions",
      "begin": "\\$\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.template-expression.begin.js" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.template-expression.end.js" }
      },
      "patterns": [
        { "include": "source.js" }
      ]
    }
  }
}
