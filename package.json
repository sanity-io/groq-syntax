{
  "name": "@sanity/groq-syntax",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "cd playground && pnpm dev",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p packages/groq-highlight-test/tsconfig.json && tsc --noEmit -p playground/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
